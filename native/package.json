{
	"name": "@flatmaxxing/accessibility",
	"version": "1.0.0",
	"description": "macOS Accessibility and CoreGraphics automation primitives for Flatmaxx",
	"main": "index.js",
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/brunostjohn/flatmaxx.git"
	},
	"license": "MIT",
	"keywords": [
		"napi-rs",
		"NAPI",
		"N-API",
		"Rust",
		"node-addon",
		"node-addon-api"
	],
	"files": [
		"index.d.ts",
		"index.js"
	],
	"napi": {
		"binaryName": "accessibility",
		"targets": [
			"x86_64-apple-darwin",
			"aarch64-apple-darwin"
		]
	},
	"engines": {
		"node": ">= 18.17.0 < 19 || >= 20.3.0 < 21 || >= 21.1.0"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public"
	},
	"scripts": {
		"artifacts": "napi artifacts",
		"build": "napi build --platform --release --no-js && node scripts/align-linkedit.js",
		"build:debug": "napi build --platform --no-js && node scripts/align-linkedit.js",
		"format": "run-p format:prettier format:rs format:toml",
		"format:prettier": "prettier . -w",
		"format:toml": "taplo format",
		"format:rs": "cargo fmt",
		"lint": "oxlint .",
		"prepublishOnly": "napi prepublish -t npm",
		"test": "bun test",
		"preversion": "napi build --platform && git add .",
		"version": "napi version",
		"prepare": "husky"
	},
	"devDependencies": {
		"@emnapi/core": "^1.5.0",
		"@emnapi/runtime": "^1.5.0",
		"@napi-rs/cli": "^3.2.0",
		"@oxc-node/core": "^0.1.0",
		"@taplo/cli": "^0.7.0",
		"@tybys/wasm-util": "^0.10.0",
		"@types/bun": "^1.3.14",
		"ava": "^8.0.0",
		"chalk": "^5.6.2",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.0",
		"npm-run-all2": "^9.0.0",
		"oxlint": "^1.14.0",
		"prettier": "^3.6.2",
		"tinybench": "^6.0.0",
		"typescript": "^6.0.0"
	},
	"lint-staged": {
		"*.@(js|ts|tsx)": [
			"oxlint --fix"
		],
		"*.@(js|ts|tsx|yml|yaml|md|json)": [
			"prettier --write"
		],
		"*.toml": [
			"taplo format"
		]
	},
	"ava": {
		"extensions": [
			"ts"
		],
		"timeout": "2m",
		"workerThreads": false,
		"environmentVariables": {
			"OXC_TSCONFIG_PATH": "./__test__/tsconfig.json"
		},
		"nodeArguments": [
			"--import",
			"@oxc-node/core/register"
		]
	},
	"prettier": {
		"printWidth": 120,
		"semi": false,
		"trailingComma": "all",
		"singleQuote": true,
		"arrowParens": "always"
	},
	"packageManager": "yarn@4.17.0"
}
