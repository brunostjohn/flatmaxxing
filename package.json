{
  "name": "flatmaxx",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "native"
  ],
  "scripts": {
    "dev": "bun run build:native && FLATMAXX_DEV=1 bun src/index.ts testdir --config flatmaxxing.dev.toml",
    "format": "biome format --write .",
    "build:native": "bun run --cwd native build",
    "build": "bun run build:native && bun scripts/build.ts && bun run codesign",
    "codesign": "codesign --force --options runtime --entitlements flatmaxx.entitlements --sign - dist/flatmaxx",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@effect/atom-react": "4.0.0-beta.84",
    "@effect/platform-bun": "4.0.0-beta.84",
    "@effect/platform-node": "4.0.0-beta.84",
    "@flatmaxxing/accessibility": "workspace:*",
    "@inkjs/ui": "^2.0.0",
    "@mishieck/ink-titled-box": "^0.4.2",
    "@resvg/resvg-js": "^2.6.2",
    "@types/bun": "latest",
    "@types/chrome-remote-interface": "^0.34.0",
    "@types/react": "^19.2.17",
    "@typescript/native-preview": "^7.0.0-dev.20260619.1",
    "chrome-remote-interface": "^0.34.0",
    "cli-spinners": "^3.4.0",
    "dxf-parser": "^1.1.2",
    "effect": "4.0.0-beta.84",
    "effect-playwright": "git+https://github.com/Jobflow-io/effect-playwright.git#effect-v4",
    "ink": "^7.1.0",
    "ink-form": "^2.0.1",
    "ink-multi-select": "^2.0.0",
    "ink-progress-bar": "^3.0.0",
    "ink-quicksearch-input": "^1.0.0",
    "ink-scroll-view": "^0.3.7",
    "ink-select-input": "^6.2.0",
    "ink-tab": "^5.2.0",
    "ink-task-list": "^2.0.0",
    "kicadts": "^0.0.47",
    "react": "^19.2.7",
    "sharp": "^0.35.2",
    "toml": "^4.1.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {}
}
