{
  "name": "flatmaxx",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "native"
  ],
  "scripts": {
    "dev": "bun run build:native && FLATMAXX_DEV=1 bun src/index.ts testdir --config flatmaxxing.dev.toml",
    "dev:root": "bun run build:native && FLATMAXX_DEV=1 bun src/index.ts",
    "dev:build": "bun run build:native && FLATMAXX_DEV=1 bun src/index.ts build",
    "dev:config": "bun run build:native && FLATMAXX_DEV=1 bun src/index.ts config",
    "dev:config:user": "bun run build:native && FLATMAXX_DEV=1 bun src/index.ts config --user",
    "dev:doctor": "bun run build:native && FLATMAXX_DEV=1 bun src/index.ts doctor",
    "dev:init": "bun run build:native && FLATMAXX_DEV=1 bun src/index.ts init",
    "dev:validate": "bun run build:native && FLATMAXX_DEV=1 bun src/index.ts validate",
    "format": "biome format --write .",
    "build:native": "bun run --cwd native build",
    "build:schema": "bun scripts/generate-schema.ts",
    "build": "bun run build:native && bun run build:schema && bun scripts/build.ts && bun run codesign",
    "codesign": "codesign --force --options runtime --entitlements flatmaxx.entitlements --sign - dist/flatmaxx",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@effect/atom-react": "4.0.0-beta.84",
    "@effect/platform-bun": "4.0.0-beta.84",
    "@effect/platform-node": "4.0.0-beta.84",
    "@flatmaxxing/accessibility": "workspace:*",
    "@img/colour": "^1.1.0",
    "@inkjs/ui": "^2.0.0",
    "@mishieck/ink-titled-box": "^0.4.2",
    "@resvg/resvg-js": "^2.6.2",
    "@types/bun": "latest",
    "@types/chrome-remote-interface": "^0.34.0",
    "@types/node": "22",
    "@types/react": "^19.2.17",
    "@typescript/native-preview": "^7.0.0-dev.20260619.1",
    "chalk": "^5.6.2",
    "chrome-remote-interface": "^0.34.0",
    "cli-spinners": "^3.4.0",
    "deepmerge-ts": "^7.1.5",
    "detect-libc": "^2.1.2",
    "dxf-parser": "^1.1.2",
    "effect": "4.0.0-beta.84",
    "effect-playwright": "git+https://github.com/Jobflow-io/effect-playwright.git#effect-v4",
    "ink": "^7.1.0",
    "ink-big-text": "^2.0.0",
    "ink-form": "^2.0.1",
    "ink-gradient": "^4.0.1",
    "ink-multi-select": "^2.0.0",
    "ink-progress-bar": "^3.0.0",
    "ink-quicksearch-input": "^1.0.0",
    "ink-scroll-view": "^0.3.7",
    "ink-select-input": "^6.2.0",
    "ink-tab": "^5.2.0",
    "ink-task-list": "^2.0.0",
    "is-unicode-supported": "^2.1.0",
    "iterm2-version": "^6.0.0",
    "jimp": "^1.6.1",
    "kicadts": "^0.0.47",
    "react": "^19.2.7",
    "semver": "^7.8.5",
    "sixel": "^0.16.0",
    "toml": "^4.1.1",
    "cfonts": "^3.3.1",
    "supports-color": "^10.2.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {}
}
