<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Bun's JIT needs these under the hardened runtime. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-executable-page-protection</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <!-- The app loads its bundled napi-rs native addon at runtime; without this
         the hardened runtime can reject loading a separately signed module. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- flatmaxx drives MakeraCAM via osascript -> System Events (Apple Events);
         the hardened runtime blocks sending Apple Events without this. The user
         still grants the Automation + Accessibility TCC prompts at first run
         (those are user permissions, not entitlements). -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
</dict>
</plist>
